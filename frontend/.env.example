# Copy to frontend/.env.local for local overrides (optional).
#
# Base URL for the backend API.
# Leave empty for local development so requests use relative `/api/...`
# paths and go through the Vite dev proxy (see vite.config.ts).
# In production (Vercel), set this to your deployed Render backend URL, e.g.:
# VITE_API_BASE_URL=https://krypto-backend.onrender.com
VITE_API_BASE_URL=
