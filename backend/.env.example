# Copy to backend/.env and fill in your real key
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5
PORT=3002

# Comma-separated list of allowed frontend origins for CORS.
# Leave unset for local development (CORS stays fully open).
# In production set this to your Vercel URL, e.g.:
# FRONTEND_ORIGIN=https://krypto.vercel.app
# FRONTEND_ORIGIN=https://krypto.vercel.app,https://www.krypto.app
